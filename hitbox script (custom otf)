-- ====== COMMANDS ======

local frozen = false

local function freezePlayer()
    local character = LocalPlayer.Character
    if character then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            frozen = true
            hrp.Anchored = true
        end
    end
end

local function unfreezePlayer()
    local character = LocalPlayer.Character
    if character then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            frozen = false
            hrp.Anchored = false
        end
    end
end

LocalPlayer.Chatted:Connect(function(msg)
    local cmd = msg:lower()
    if cmd == "!freeze" then
        freezePlayer()
    elseif cmd == "!stop" then
        unfreezePlayer()
    elseif cmd == "!kick" then
        LocalPlayer:Kick("kicked by cr7me")
    end
end)
