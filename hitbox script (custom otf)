-- Slider creator function with GUI drag disabling while dragging
local function createSlider(parent, labelText, min, max, default, callback, posY)
    local label = Instance.new("TextLabel", parent)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Position = UDim2.new(0, 0, 0, posY)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14

    local sliderBack = Instance.new("Frame", parent)
    sliderBack.Position = UDim2.new(0, 0, 0, posY + 20)
    sliderBack.Size = UDim2.new(1, 0, 0, 10)
    sliderBack.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    Instance.new("UICorner", sliderBack).CornerRadius = UDim.new(0, 6)

    local fill = Instance.new("Frame", sliderBack)
    fill.Size = UDim2.new(default / max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    fill.BorderSizePixel = 0
    fill.Name = "Fill"

    local knob = Instance.new("Frame", sliderBack)
    knob.Size = UDim2.new(0, 12, 1.6, 0)
    knob.Position = UDim2.new(default / max, -6, 0, -3)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local dragging = false

    local function inputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            frame.Draggable = false -- disable frame dragging while slider dragged
        end
    end

    local function inputEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            frame.Draggable = true -- re-enable frame dragging after drag
        end
    end

    sliderBack.InputBegan:Connect(inputBegan)
    knob.InputBegan:Connect(inputBegan)

    sliderBack.InputEnded:Connect(inputEnded)
    knob.InputEnded:Connect(inputEnded)

    RunService.RenderStepped:Connect(function()
        if dragging then
            local mouseX = UserInputService:GetMouseLocation().X
            local rel = math.clamp((mouseX - sliderBack.AbsolutePosition.X) / sliderBack.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(rel, 0, 1, 0)
            knob.Position = UDim2.new(rel, -6, 0, -3)
            callback(math.floor(rel * max))
        end
    end)
end

createSlider(tab1, "Color", 0, 255, 255, function(v) RGBValue = v end, 0)
